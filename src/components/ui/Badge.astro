---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

interface Props {
  status: 'live' | 'beta' | 'wip';
  label?: string;
  class?: string;
}

const { status, label, class: className = '' } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const displayLabel = label || t(`project.status.${status}`);
---

<span class={`badge badge-${status} ${className}`}>
  {displayLabel}
</span>