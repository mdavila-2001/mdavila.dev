---
import Button from '../ui/Button.astro';
import '../../styles/Hero.scss';
---

<section class="hero-section">

  <!-- Glow -->
  <div class="glow glow-1"></div>
  <div class="glow glow-2"></div>

  <div class="hero-container">

    <!-- BADGE -->
    <div class="hero-badge">
      <span class="dot"></span>
      Disponible para freelance
    </div>

    <!-- TITLE -->
    <h1>
      Marcelo <span>Dávila</span>
    </h1>

    <!-- SUBTITLE -->
    <h2>
      QA Engineer · Fullstack Web & Mobile
    </h2>

    <!-- DESCRIPTION -->
    <p>
      Construyo sistemas escalables, automatizo procesos y aseguro la calidad del software 
      con testing avanzado y desarrollo backend moderno.
    </p>

    <!-- BUTTONS -->
    <div class="hero-buttons">
      <Button variant="primary">
        Ver proyectos →
      </Button>

      <Button variant="secondary">
        Contactar
      </Button>
    </div>

  </div>

</section>