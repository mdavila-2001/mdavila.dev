---
import { skills } from '../../data/skills';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import '../../styles/Skills.scss';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="skills-section">

    <div class="skills-header reveal">
      <h2>{t('skills.title')}</h2>
      <p>{t('skills.subtitle')}</p>
    </div>

    <div class="skills-scroller-wrap reveal delay-200">
      <button class="scroller-arrow left hidden" aria-label="Scroll left">
        <span class="material-symbols-outlined">chevron_left</span>
      </button>

      <div class="skills-scroll-track">
        <div class="skills-scroll-content">
          {skills.map((skill) => (
            <div class={`skill-card ${skill.color}`}>

              <div class="bg-icon">
                <span class="material-symbols-outlined">
                  {skill.icon}
                </span>
              </div>

              <div class="icon">
                <span class="material-symbols-outlined">
                  {skill.icon}
                </span>
              </div>

              <h3>{t(`${skill.key}.title` as any)}</h3>
              <p class="desc">{t(`${skill.key}.desc` as any)}</p>

              <ul>
                {skill.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>

            </div>
          ))}
        </div>
      </div>

      <button class="scroller-arrow right" aria-label="Scroll right">
        <span class="material-symbols-outlined">chevron_right</span>
      </button>
    </div>

</section>



<script>
  document.addEventListener('DOMContentLoaded', () => {
    const wrap = document.querySelector('.skills-scroller-wrap');
    if (!wrap) return;

    const track = wrap.querySelector('.skills-scroll-track') as HTMLElement;
    const leftBtn = wrap.querySelector('.scroller-arrow.left') as HTMLButtonElement;
    const rightBtn = wrap.querySelector('.scroller-arrow.right') as HTMLButtonElement;

    if (!track || !leftBtn || !rightBtn) return;

    const updateArrows = () => {
      // On desktop, hide arrows entirely
      if (window.innerWidth >= 1024) {
        leftBtn.classList.add('hidden');
        rightBtn.classList.add('hidden');
        return;
      }

      const atStart = track.scrollLeft <= 5;
      const atEnd = track.scrollLeft + track.clientWidth >= track.scrollWidth - 5;

      leftBtn.classList.toggle('hidden', atStart);
      rightBtn.classList.toggle('hidden', atEnd);
    };

    updateArrows();
    track.addEventListener('scroll', updateArrows);
    window.addEventListener('resize', updateArrows);

    const scrollAmount = () => {
      // Scroll by one card width
      const firstCard = track.querySelector('.skill-card') as HTMLElement;
      return firstCard ? firstCard.offsetWidth + 24 : 320; // card width + gap
    };

    leftBtn.addEventListener('click', () => {
      track.scrollBy({ left: -scrollAmount(), behavior: 'smooth' });
    });
    rightBtn.addEventListener('click', () => {
      track.scrollBy({ left: scrollAmount(), behavior: 'smooth' });
    });
  });
</script>